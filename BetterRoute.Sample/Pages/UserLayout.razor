@code {
    [CascadingParameter] public RouterState State { get; set; } = default!;
}

<div style="border: 2px dashed #2a8c4a; padding: 12px; border-radius: 6px; margin-top: 8px;">
    <h2 style="margin-top: 0;">User @State.Parameters["userId"]</h2>
    <p style="color: #555;">Inner layout for one user. The <code>userId</code> parameter is visible here and to deeper levels.</p>
    <nav style="margin-bottom: 8px;">
        <a href="users/@State.Parameters["userId"]">overview</a> ·
        <a href="users/@State.Parameters["userId"]/profile">profile</a> ·
        <a href="users/@State.Parameters["userId"]/search?q=blazor&sort=asc">search</a> ·
        <a href="users/@State.Parameters["userId"]/posts/1">post 1</a> ·
        <a href="users/@State.Parameters["userId"]/posts/2">post 2</a>
    </nav>
    <div style="display: flex; gap: 16px;">
        <div style="flex: 1; min-width: 0;">
            <RouterOutlet />
        </div>
        <aside style="width: 220px; flex-shrink: 0;">
            <RouterOutlet Name="sidebar" />
        </aside>
    </div>
</div>
