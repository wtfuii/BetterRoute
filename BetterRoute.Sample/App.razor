<header style="padding: 12px 20px; border-bottom: 1px solid #ddd; background: #f7f7f9;">
    <strong>BetterRoute demo</strong>
    &nbsp;|&nbsp;
    <RouteLink Href="">home</RouteLink> ·
    <RouteLink Href="users">users</RouteLink> ·
    <RouteLink Href="users/42/profile">user 42 profile</RouteLink> ·
    <RouteLink Href="users/42/posts/7">user 42 post 7</RouteLink> ·
    <RouteLink Href="users/42/search?q=blazor&sort=asc">user 42 search</RouteLink> ·
    <RouteLink Href="users/99/profile">user 99 profile</RouteLink> ·
    <RouteLink Href="users/42/stats">user 42 stats (sidebar)</RouteLink> ·
    <RouteLink Href="profile">profile (redirect)</RouteLink> ·
    <RouteLink Href="home">home (alias)</RouteLink> ·
    <RouteLink Href="ghost">unknown</RouteLink>
</header>

<main style="padding: 20px;">
    <BetterRouter Routes="@Routes" NotFound="typeof(NotFoundPage)" />
</main>

@code {
    private static readonly IReadOnlyList<RouteDefinition> Routes =
    [
        new RouteDefinition("", typeof(Home), Aliases: ["home"]),
        new RouteDefinition("profile", RedirectTo: "/users/42/profile"),
        new RouteDefinition("users", typeof(UsersLayout), Name: "users", Children:
        [
            new RouteDefinition("", typeof(UsersIndex)),
            new RouteDefinition(":userId", typeof(UserLayout), Children:
            [
                new RouteDefinition("", typeof(UserOverview)),
                new RouteDefinition("profile", typeof(UserProfile)),
                new RouteDefinition("search", typeof(UserSearch),
                    Components: new Dictionary<string, Type>
                    {
                        ["sidebar"] = typeof(UserSidebar),
                    }),
                new RouteDefinition("posts/:postId", typeof(UserPost),
                    Name: "user.post",
                    Components: new Dictionary<string, Type>
                    {
                        ["sidebar"] = typeof(UserSidebar),
                    }),
                new RouteDefinition("stats", typeof(UserStats),
                    Components: new Dictionary<string, Type>
                    {
                        ["sidebar"] = typeof(UserSidebar),
                    }),
            ]),
        ]),
    ];
}
