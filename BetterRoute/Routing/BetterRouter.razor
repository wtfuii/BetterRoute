@namespace BetterRoute.Routing
@implements IDisposable

@if (_state is not null)
{
    <CascadingValue Value="_state" IsFixed="false">
        <CascadingValue Value="_guardRegistrar" IsFixed="true">
            @RenderRoot(_state)
        </CascadingValue>
    </CascadingValue>
}
else if (_initialNavigationComplete && NotFound is not null)
{
    <DynamicComponent Type="NotFound" />
}
